# Supabase configuration used by the Vite frontend.
# Set these in your hosting provider before deploy.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Optional public app URL, used by hosting/deploy notes and future public links.
VITE_APP_URL="https://your-domain.example"
